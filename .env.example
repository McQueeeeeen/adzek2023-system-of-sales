# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Telegram reminders
TELEGRAM_BOT_TOKEN=123456789:telegram-bot-token
TELEGRAM_CHAT_ID=123456789

# Protect cron/manual endpoint access
CRON_SECRET=replace-with-strong-secret

# Kazakhstan timezone for operational reminders
KZ_TIMEZONE=Asia/Almaty
TELEGRAM_BLOCK_LIMIT=5
